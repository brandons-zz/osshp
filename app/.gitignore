# Build output
.next/
out/

# Dependencies (no trailing slash so a node_modules SYMLINK is ignored too — a
# trailing-slash pattern matches directories only and lets a symlink slip in)
node_modules

# Environment files (never commit .env — only .env.example is tracked)
.env
.env.local
.env.*.local

# Bun lockfile (committed — tracks exact deps)
# bun.lock — tracked intentionally

