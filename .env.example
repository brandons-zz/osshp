# ============================================================
# osshp — Operator Configuration
# ============================================================
# Copy this file to .env and fill in every CHANGE_ME value.
# Then copy config/garage.toml.example → config/garage.toml
# and fill in the Garage RPC secret.
#
# SECURITY: Never commit your .env file to version control.
# ============================================================

# --- Site domain -----------------------------------------------
# Domain where this osshp instance is served.
# Local dev:  localhost
# VPS:        yourdomain.com
OSSHP_DOMAIN=CHANGE_ME

# --- WebAuthn (passkey) ----------------------------------------
# SECURITY: These are pinned at setup from operator config.
# They are NEVER derived from request Host/X-Forwarded-Host headers.
# Docs: https://www.w3.org/TR/webauthn/#relying-party-identifier
#
# RP ID — the domain only, no scheme or port.
# Example: yourdomain.com
OSSHP_RP_ID=CHANGE_ME
#
# Expected origin — full origin including scheme.
# Example: https://yourdomain.com
OSSHP_ORIGIN=CHANGE_ME
#
# Optional: user-visible Relying Party display name (cosmetic). Defaults to "osshp".
# OSSHP_RP_NAME=My Blog

# --- Session ---------------------------------------------------
# 256-bit session signing secret. REQUIRED — the app refuses to start without
# a strong value (leaving this blank fails as "missing", not a rejected literal).
# Generate with: openssl rand -hex 32
SESSION_SECRET=
#
# Session cookies are Secure by default (TLS terminates in-stack via Caddy).
# Set this to "true" ONLY for local http://localhost dev — NEVER in production.
# SESSION_COOKIE_INSECURE=true

# --- Encryption -----------------------------------------------
# AES-256-GCM key for encrypting TOTP secrets at rest.
# Required when TOTP enroll/recovery is in use; the app refuses to start
# the TOTP lane without it (fail-closed — no silent plaintext storage).
# Leave blank to fail as "missing" rather than a rejected placeholder.
# Generate with: openssl rand -hex 32
OSSHP_ENCRYPTION_KEY=

# --- Database --------------------------------------------------
POSTGRES_DB=osshp
POSTGRES_USER=osshp
# Generate with: openssl rand -hex 24
# Use -hex, not -base64: this value is substituted directly into
# DATABASE_URL below, and base64 output can contain / or + which
# break URL parsing.
POSTGRES_PASSWORD=CHANGE_ME

# Database URL for the app (uses the compose db service by default).
# Substitute your POSTGRES_PASSWORD value in place of CHANGE_ME below.
DATABASE_URL=postgresql://osshp:CHANGE_ME@db:5432/osshp

# --- Object Storage (Garage) -----------------------------------
# After first-run Garage provisioning (see docs/setup-runbook.md),
# fill in the generated access key and secret key here.
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME
S3_BUCKET=osshp-media
S3_REGION=us-east-1

# --- Ports (optional) ------------------------------------------
# Change only if ports 80/443 are already in use on the host.
# (Ignored in Cloudflare Tunnel mode — the tunnel overlay publishes no
# host ports; cloudflared reaches the proxy over the internal network.)
HTTP_PORT=80
HTTPS_PORT=443

# --- Deployment mode (optional) --------------------------------
# DIRECT (default): Caddy terminates public TLS on 80/443 (Let's Encrypt).
#   Nothing below is needed. `docker compose up -d` is the full command.
#
# CLOUDFLARE TUNNEL: for home / dynamic-IP / CGNAT hosts with no open ports.
#   `./scripts/setup.sh --mode tunnel --tunnel-token <token>` fills the two
#   values below for you and brings the stack up with the tunnel overlay.
#   See docs/setup-runbook.md → "Cloudflare Tunnel mode". Set by hand only if
#   you are configuring without setup.sh:
#
#   Caddy site address. Leave UNSET for direct mode (Caddy defaults to the
#   bare OSSHP_DOMAIN and does auto-HTTPS). For tunnel mode set it to
#   http://<domain> so Caddy serves plain HTTP behind the tunnel:
# OSSHP_CADDY_SITE_ADDRESS=http://yourdomain.com
#
#   Cloudflare Tunnel connector token (a SECRET — never commit .env).
#   Retrieve with `cloudflared tunnel token <name>` or the Zero Trust dashboard:
# CLOUDFLARE_TUNNEL_TOKEN=
#
#   Trusted reverse-proxy hop count for resolving the real client IP from
#   X-Forwarded-For (used by the auth rate-limiter and analytics). Direct
#   mode has one hop (Caddy) and defaults to 1 — leave unset. Tunnel mode
#   has TWO hops (Cloudflare's edge, then Caddy) — setup.sh sets this to 2
#   for you. See docs/setup-runbook.md → "Trusted proxy hops" before
#   setting it by hand.
# OSSHP_TRUSTED_PROXY_HOPS=2
